# =====================================================
# FITPRO — Required Environment Variables
# Copy this file to .env and fill in the values
# =====================================================

# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Authentication (generate a strong random secret)
JWT_SECRET=your-strong-random-secret-at-least-32-characters

# Resend API Key — used for:
#   - Email confirmation on registration
#   - Password reset emails
# Get your key at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Application URL (used for email confirmation links)
APP_URL=https://your-app.vercel.app

# =====================================================
# Optional Variables
# =====================================================

# Node environment
# NODE_ENV=production

# S3 Storage (for profile photo uploads)
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_REGION=us-east-1
# S3_BUCKET=
# S3_ENDPOINT=
