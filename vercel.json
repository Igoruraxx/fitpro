{
  "version": 2,
  "buildCommand": "vite build && pnpm esbuild api/index.ts --bundle --platform=node --format=cjs --outfile=api/_built.cjs",
  "outputDirectory": "dist/public",
  "framework": null,
  "functions": {
    "api/_built.cjs": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/_built.cjs"
    },
    {
      "source": "/((?!api).*)",
      "destination": "/index.html"
    }
  ]
}
